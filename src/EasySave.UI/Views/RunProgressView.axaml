<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:EasySave.UI.ViewModels"
             xmlns:markup="using:EasySave.UI.Markup"
             xmlns:converters="using:EasySave.UI.Converters"
             x:Class="EasySave.UI.Views.RunProgressView"
             x:DataType="vm:RunProgressViewModel"
             x:CompileBindings="False">

    <DockPanel Margin="32,28,32,24">

        <!-- Header -->
        <TextBlock DockPanel.Dock="Top"
                   Text="{markup:T Key=progress.title}"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Foreground="#111827"
                   Margin="0,0,0,20" />

        <!-- Business software banner -->
        <Border DockPanel.Dock="Top"
                IsVisible="{Binding IsBusinessSoftwareDetected}"
                Background="#FF6B35"
                CornerRadius="6"
                Padding="14,10"
                Margin="0,0,0,16">
            <TextBlock Foreground="White" VerticalAlignment="Center">
                <Run Text="{markup:T Key=progress.business_pause}" />
                <Run Text="{Binding DetectedSoftwareName}" FontWeight="Bold" />
            </TextBlock>
        </Border>

        <!-- Close button -->
        <Button DockPanel.Dock="Bottom"
                Command="{Binding CloseProgressCommand}"
                Content="{markup:T Key=progress.close}"
                HorizontalAlignment="Center"
                Margin="0,16,0,0"
                Padding="20,10" />

        <!-- Job progress list -->
        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Jobs}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:BackupJobVM">
                        <Border Background="{StaticResource CardBackgroundBrush}"
                                CornerRadius="8"
                                Padding="16,14"
                                Margin="0,0,0,10"
                                BoxShadow="0 1 4 0 #15000000">
                            <StackPanel Spacing="8">

                                <!-- Job name + state badge -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding Name}"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="#111827"
                                               VerticalAlignment="Center" />
                                    <Border Grid.Column="1"
                                            CornerRadius="12"
                                            Padding="10,4">
                                        <Border.Background>
                                            <Binding Path="UiState"
                                                     Converter="{StaticResource StateToColorConverter}" />
                                        </Border.Background>
                                        <TextBlock Text="{Binding StateDisplayName}"
                                                   Foreground="White"
                                                   FontSize="11"
                                                   FontWeight="Medium" />
                                    </Border>
                                </Grid>

                                <!-- Progress bar -->
                                <ProgressBar Value="{Binding Progress}"
                                             Minimum="0"
                                             Maximum="100"
                                             Height="8"
                                             CornerRadius="4" />

                                <!-- Percentage -->
                                <TextBlock Text="{Binding Progress, StringFormat='{}{0} %'}"
                                           HorizontalAlignment="Right"
                                           FontSize="12"
                                           Foreground="{StaticResource MutedTextBrush}" />

                                <!-- Current file -->
                                <TextBlock Text="{Binding CurrentFile}"
                                           FontSize="11"
                                           Foreground="{StaticResource MutedTextBrush}"
                                           TextTrimming="CharacterEllipsis"
                                           IsVisible="{Binding IsRunning}" />

                                <!-- Files remaining -->
                                <StackPanel Orientation="Horizontal"
                                            Spacing="4"
                                            IsVisible="{Binding IsRunning}">
                                    <TextBlock Text="{markup:T Key=progress.files_remaining}"
                                               FontSize="11"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                    <TextBlock Text="{Binding FilesRemaining}"
                                               FontSize="11"
                                               Foreground="{StaticResource MutedTextBrush}" />
                                </StackPanel>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

    </DockPanel>
</UserControl>
